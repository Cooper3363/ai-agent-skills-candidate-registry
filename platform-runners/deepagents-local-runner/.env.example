OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPAGENTS_MODEL=openai:gpt-5.5

# Optional: keep the runner in preflight mode even when a key is present.
# Set to 1 to skip model invocations and only validate environment + skill loading.
DEEPAGENTS_METADATA_ONLY=0

# Optional controlled image relay smoke. Never commit real values.
# The runner requires REAL_MEDIA_SMOKE_APPROVED=1 and --execute before it calls the relay.
REAL_MEDIA_SMOKE_APPROVED=0
IMAGE_RELAY_BASE_URL=
IMAGE_RELAY_API_KEY=
IMAGE_RELAY_ENDPOINT=/images/generations
IMAGE_RELAY_MODEL=gpt-image-1
IMAGE_RELAY_SIZE=1024x1024
IMAGE_RELAY_RESPONSE_FORMAT=b64_json
